{
  "name": "vuetify-project",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "mcp": "ruler apply",
    "mcp:revert": "ruler revert",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "@mdi/font": "^7.4.47",
    "@vuepic/vue-datepicker": "^12.1.0",
    "axios": "^1.15.0",
    "date-fns": "^4.1.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "spark-md5": "^3.0.2",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "vue-router": "^5.0.4",
    "vuetify": "^4.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@intellectronica/ruler": "^0.3.38",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-vuetify": "^4.5.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "sass-embedded": "^1.99.0",
    "typescript": "~5.9.3",
    "unplugin-fonts": "^2.0.0",
    "vite": "^8.0.8",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-tsc": "^3.2.6"
  },
  "lint-staged": {
    "*.{ts,vue,js,mts}": [
      "eslint --fix"
    ],
    "*.{ts,vue,js,mts,json,scss,css,md,html}": [
      "prettier --write"
    ]
  }
}
